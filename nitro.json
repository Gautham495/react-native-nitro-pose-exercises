{
  "cxxNamespace": ["nitroposeexercises"],
  "ios": {
    "iosModuleName": "NitroPoseExercises"
  },
  "android": {
    "androidNamespace": ["nitroposeexercises"],
    "androidCxxLibName": "nitroposeexercises"
  },
  "autolinking": {
    "NitroPoseExercises": {
      "ios": {
